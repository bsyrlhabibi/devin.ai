# Alchemy API key used for the Alchemy-hosted RPC endpoints of every
# supported network in config/networks.yaml. When this value is set (and
# callers don't pass ``use_alchemy=False``) the agent transparently
# prefers Alchemy over the public RPC. Leave blank to fall back to the
# public endpoints for every chain.
ALCHEMY_API_KEY=

# Password used to encrypt/decrypt local wallet private keys.
# Set this to a strong value and never commit your real .env file.
PRIVATE_KEY_PASSWORD=change_me_to_a_strong_password

# Optional: per-network RPC overrides. Each variable, when set, replaces
# the ``public`` RPC URL for that network. This is useful if you run your
# own node or have a private RPC provider (Infura, QuickNode, etc.).
ETHEREUM_RPC_URL=
SEPOLIA_RPC_URL=
GOERLI_RPC_URL=
ARBITRUM_RPC_URL=
ARBITRUM_NOVA_RPC_URL=
OPTIMISM_RPC_URL=
BASE_RPC_URL=
ZKSYNC_ERA_RPC_URL=
POLYGON_ZKEVM_RPC_URL=
LINEA_RPC_URL=
SCROLL_RPC_URL=
MANTLE_RPC_URL=
POLYGON_RPC_URL=
MUMBAI_RPC_URL=
BSC_RPC_URL=
BSC_TESTNET_RPC_URL=
AVALANCHE_RPC_URL=
FANTOM_RPC_URL=
AURORA_RPC_URL=
HARMONY_RPC_URL=
CRONOS_RPC_URL=
MOONBEAM_RPC_URL=
MOONRIVER_RPC_URL=
CELO_RPC_URL=
GNOSIS_RPC_URL=
ASTAR_RPC_URL=
METIS_RPC_URL=
